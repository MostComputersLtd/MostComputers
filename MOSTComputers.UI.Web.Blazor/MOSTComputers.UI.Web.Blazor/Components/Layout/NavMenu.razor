@implements IDisposable

@inject NavigationManager NavigationManager

<div class="nav-with-scrollable-part-container" onclick="document.getElementById('hidden-navbar-toggler').click()">
    <nav class="custom-navbar nav-with-scrollable-part">

        <a class="navbar-brand" href="/">
            <img class="navbar-brand-image navbar-brand-image-big" src="/img/Logos/logo-navbar-big.svg" />
            <img class="navbar-brand-image navbar-brand-image-small" src="/img/Logos/logo-navbar-small.svg" />
        </a>

        <address class="navbar-brand-contacts">
            <span>Phone: (+359 2) 91 823</span>
            <span>e-mail: info@mostbg.com</span>
        </address>

        <div class="navbar-toggler-container">
            <button for="hidden-navbar-toggler" title="Toggle navigation" class="navbar-toggler"
                onclick="event.stopPropagation(); document.getElementById('hidden-navbar-toggler').click()" />
        </div>

        <input id="hidden-navbar-toggler" type="checkbox" class="hidden-navbar-toggler" />

        <div class="nav-scrollable">
            <div class="nav-item">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" data-enhance-nav="false">
                    Home
                </NavLink>
            </div>

			<div class="nav-item">
                <a class="nav-link" href="promotions" data-enhance-nav="false">
                    Promotions
                </a>
            </div>

            <div class="nav-item">
                <a class="nav-link" href="downloadXml" data-enhance-nav="false">
                    XML
                </a>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="repairs">
                    Repairs
                </NavLink>
            </div>

            <AuthorizeView Roles="ProductEditor">
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="productEditor" data-enhance-nav="false">
                            Product Editor
                        </NavLink>
                    </div>
				</Authorized>
			</AuthorizeView>

			<AuthorizeView Roles="PromotionEditor">
                <Authorized>
                    <div class="nav-item">
                        <a class="nav-link" href="promotionGroups" data-enhance-nav="false">
                            Promotion Groups
                        </a>
                    </div>
				</Authorized>
			</AuthorizeView>

			<AuthorizeView Roles="ProductEditor">
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="promotionFiles">
                            Promotion Files
                        </NavLink>
                    </div>
				</Authorized>
			</AuthorizeView>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="productBarcodeScanner">
                            Barcode Scanner
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="_tests/_temp_transferDataTests">
                            Data Tests
                        </NavLink>
                    </div>

                    @* <div class="nav-item">
                        <NavLink class="nav-link" href="_tests/_temp_imagesCreationTests">
                            Image Tests
                        </NavLink>
                    </div> *@

                    @* <div class="nav-item">
                        <NavLink class="nav-link nav-link-nowrap" href="/legacyXmlCharacteristicsMatch">
                            Match Characteristics (XML)
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link nav-link-nowrap" href="/imageHtmlCharacteristicsMatch">
                            Match Characteristics (HTML)
                        </NavLink>
                    </div> *@
                    
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Admin,Employee,CustomerInvoiceViewer">
                <div class="nav-item">
                    <NavLink class="nav-link" href="documents">
                        Documents
                    </NavLink>
                </div>
            </AuthorizeView>

            <div class="nav-end-data-container">
				<div class="nav-item">
                    <a class="nav-link" href="http://www.mostbg.com/most/PriceList.aspx" target="_blank">
                        Вход B2B
                    </a>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="contactUs">
                        Contact us
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="account/manage/adminPanel">
                                AMP
                            </NavLink>
                        </div>
					</Authorized>
				</AuthorizeView>

                <AuthorizeView>
                    <Authorized>
                        <div class="nav-inactive-item nav-user-name-item">
                            <p>
                                @context.User.Identity?.Name
                            </p>
                        </div>
                        <div class="nav-item">
                            <form action="account/logout" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                <button type="submit" class="nav-link">
                                    Logout
                                </button>
                            </form>
                        </div>
                    </Authorized>

                    <NotAuthorized>
                        <div class="nav-item">
                            <a class="nav-link" href="account/login" data-enhance-nav="false">
                                Login
                            </a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);

        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}